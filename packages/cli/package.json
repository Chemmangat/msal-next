{
  "name": "@chemmangat/msal-next-cli",
  "version": "5.0.0",
  "description": "CLI tool for setting up @chemmangat/msal-next in Next.js projects",
  "main": "./dist/index.js",
  "bin": {
    "msal-next": "./dist/cli.js"
  },
