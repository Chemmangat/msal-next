{
  "name": "@chemmangat/msal-next",
  "version": "5.0.0",
  "description": "Production-ready Microsoft/Azure AD authentication for Next.js App Router. Zero-config setup, TypeScript-first, multi-account support, auto token refresh. The easiest way to add Microsoft login to your Next.js app.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "MIGRATION_GUIDE_v3.md",
    "SECURITY.md",
    "TROUBLESHOOTING.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "msal",
    "nextjs",
    "next.js",
    "next-js",
    "authentication",
    "auth",
    "azure-ad",
    "azure",
    "microsoft",
    "microsoft-auth",
    "microsoft-login",
    "microsoft-authentication",
    "oauth",
    "oauth2",
    "app-router",
    "typescript",
    "sso",
    "single-sign-on",
    "microsoft-graph",
    "graph-api",
    "multi-account",
    "multi-tenant",
    "azure-authentication",
    "next-auth-alternative",
    "azure-login",
    "entra-id",
    "microsoft-entra",
    "msal-react",
    "msal-browser",
    "zero-config",
    "token-refresh",
    "protected-routes",
    "role-based-access"
  ],
  "author": "Hari Manoj (chemmangat)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chemmangat/msal-next.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/chemmangat/msal-next#readme",
  "bugs": {
    "url": "https://github.com/chemmangat/msal-next/issues"
  },
  "peerDependencies": {
    "@azure/msal-browser": "^3.11.0 || ^4.0.0",
    "@azure/msal-react": "^2.0.0 || ^3.0.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@azure/msal-browser": "^3.11.1",
    "@azure/msal-react": "^2.0.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.0.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/react": "^18.2.0",
    "@vitest/coverage-v8": "^1.0.0",
    "jsdom": "^23.0.0",
    "react": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
